/***********************************************************************
 *  RampControl V1.1
 *----------------------------------------------------------------------
 *  Autor: Rodrigo Vicente + ChatGPT
 *  Plataforma: Arduino UNO R3
 *
 *  Control de una rampa de estacionamiento de un solo carril.
 *
 *  Secuencia de entrada:
 *      E1 -> E2 -> E3
 *
 *  Secuencia de salida:
 *      E3 -> E2 -> E1
 *
 *  Programación:
 *      ✔ Máquina de estados
 *      ✔ Sin delay()
 *      ✔ Prioridad entre vehículos
 *      ✔ Detección por flanco
 ***********************************************************************/

//====================== PINES ======================

// Sensores
const byte SENSOR_ENTRADA = 2;
const byte SENSOR_CENTRO  = 3;
const byte SENSOR_SALIDA  = 4;

// Semáforos
const byte ROJO_ENTRADA  = 8;
const byte ROJO_SALIDA   = 9;
const byte VERDE_ENTRADA = 10;
const byte VERDE_SALIDA  = 11;


//====================== TIEMPOS ======================

const unsigned long TIEMPO_LLEGAR_CENTRO = 15000UL;
const unsigned long TIEMPO_E2_E3 = 30000UL;
const unsigned long TIEMPO_VERDE         = 3000UL;
const unsigned long TIEMPO_INACTIVIDAD   = 300000UL;
const unsigned long TIEMPO_PARPADEO      = 500UL;
const unsigned long TIEMPO_ALARMA = 10000UL;

//====================== ESTADOS ======================

enum EstadoSistema
{
    REPOSO,

    ENTRADA_ESPERA_CENTRO,
    ENTRADA_ESPERA_SALIDA,

    SALIDA_ESPERA_CENTRO,
    SALIDA_ESPERA_ENTRADA,

    VERDE_ENTRADA,
    VERDE_SALIDA,

    ALARMA
};

EstadoSistema estadoActual = REPOSO;


//====================== TEMPORIZADORES ======================

unsigned long tiempoEstado = 0;
unsigned long ultimoMovimiento = 0;
unsigned long tiempoParpadeo = 0;


//====================== VARIABLES ======================

bool parpadeo = false;


//====================== DETECCIÓN POR FLANCO ======================

bool anteriorE1 = HIGH;
bool anteriorE2 = HIGH;
bool anteriorE3 = HIGH;


//====================== FUNCIONES ======================

bool flancoEntrada()
{
    bool actual = digitalRead(SENSOR_ENTRADA);

    bool pulso = (anteriorE1 == HIGH && actual == LOW);

    anteriorE1 = actual;

    return pulso;
}

bool flancoCentro()
{
    bool actual = digitalRead(SENSOR_CENTRO);

    bool pulso = (anteriorE2 == HIGH && actual == LOW);

    anteriorE2 = actual;

    return pulso;
}

bool flancoSalida()
{
    bool actual = digitalRead(SENSOR_SALIDA);

    bool pulso = (anteriorE3 == HIGH && actual == LOW);

    anteriorE3 = actual;

    return pulso;
}


//====================== CAMBIO DE ESTADO ======================

void cambiarEstado(EstadoSistema nuevoEstado)
{
    estadoActual = nuevoEstado;
    tiempoEstado = millis();

    Serial.print("Estado -> ");
    Serial.println((int)estadoActual);
}


//====================== SEMÁFOROS ======================

void apagarTodo()
{
    digitalWrite(ROJO_ENTRADA, LOW);
    digitalWrite(ROJO_SALIDA, LOW);

    digitalWrite(VERDE_ENTRADA, LOW);
    digitalWrite(VERDE_SALIDA, LOW);
}


void semaforoEntradaBloqueada()
{
    apagarTodo();

    digitalWrite(ROJO_ENTRADA, HIGH);
}


void semaforoSalidaBloqueada()
{
    apagarTodo();

    digitalWrite(ROJO_SALIDA, HIGH);
}


void semaforoEntradaLibre()
{
    apagarTodo();

    digitalWrite(VERDE_ENTRADA, HIGH);
}


void semaforoSalidaLibre()
{
    apagarTodo();

    digitalWrite(VERDE_SALIDA, HIGH);
}


//====================== ALARMA ======================

void entrarAlarma()
{
    cambiarEstado(ALARMA);

    tiempoParpadeo = millis();

    Serial.println("***** ALARMA *****");
}
//====================== INACTIVIDAD ======================

void verificarInactividad()
{
    if (estadoActual == REPOSO)
    {
        if (millis() - ultimoMovimiento >= TIEMPO_INACTIVIDAD)
        {
            apagarTodo();
        }
    }
}
//====================== INICIAR ENTRADA ======================

void iniciarEntrada()
{
    ultimoMovimiento = millis();

    semaforoSalidaBloqueada();

    cambiarEstado(ENTRADA_ESPERA_CENTRO);

    Serial.println("=== INICIO ENTRADA ===");
}


//====================== INICIAR SALIDA ======================

void iniciarSalida()
{
    ultimoMovimiento = millis();

    semaforoEntradaBloqueada();

    cambiarEstado(SALIDA_ESPERA_CENTRO);

    Serial.println("=== INICIO SALIDA ===");
}


//============================================================
// SETUP
//============================================================

void setup()
{
    pinMode(SENSOR_ENTRADA, INPUT_PULLUP);
    pinMode(SENSOR_CENTRO, INPUT_PULLUP);
    pinMode(SENSOR_SALIDA, INPUT_PULLUP);

    pinMode(ROJO_ENTRADA, OUTPUT);
    pinMode(ROJO_SALIDA, OUTPUT);
    pinMode(VERDE_ENTRADA, OUTPUT);
    pinMode(VERDE_SALIDA, OUTPUT);

    apagarTodo();

    Serial.begin(9600);

    Serial.println();
    Serial.println("====================================");
    Serial.println("       RampControl V1.1");
    Serial.println(" Sistema iniciado correctamente");
    Serial.println("====================================");

    ultimoMovimiento = millis();
}


//============================================================
// LOOP PRINCIPAL (BASE)
//============================================================

void loop()
{
    switch (estadoActual)
    {

        //----------------------------------------------------
        case REPOSO:

            if (flancoEntrada())
            {
                iniciarEntrada();
            }

            else if (flancoSalida())
            {
                iniciarSalida();
            }

        break;
      


        //----------------------------------------------------
        case ENTRADA_ESPERA_CENTRO:

    // ¿El vehículo llegó al sensor central?
    if (flancoCentro())
    {
        ultimoMovimiento = millis();

        cambiarEstado(ENTRADA_ESPERA_SALIDA);

        Serial.println("Vehiculo detectado en E2");
    }

    // ¿No llegó en 15 segundos?
    else if (millis() - tiempoEstado >= TIEMPO_LLEGAR_CENTRO)
    {
        entrarAlarma();
    }

break;



        //----------------------------------------------------
        case ENTRADA_ESPERA_SALIDA:

    // ¿El vehículo llegó a la salida?
    if (flancoSalida())
    {
        ultimoMovimiento = millis();

        semaforoSalidaLibre();

        cambiarEstado(VERDE_SALIDA);

        Serial.println("Vehiculo termino de subir");
    }

break;


        //----------------------------------------------------
case SALIDA_ESPERA_CENTRO:

    // ¿El vehículo llegó al sensor central?
    if (flancoCentro())
    {
        ultimoMovimiento = millis();

        cambiarEstado(SALIDA_ESPERA_ENTRADA);

        Serial.println("Vehiculo detectado en E2");
    }

    // ¿No llegó en 15 segundos?
    else if (millis() - tiempoEstado >= TIEMPO_LLEGAR_CENTRO)
    {
        entrarAlarma();
    }

break;


//----------------------------------------------------
case SALIDA_ESPERA_ENTRADA:

    // ¿El vehículo llegó a la entrada?
    if (flancoEntrada())
    {
        ultimoMovimiento = millis();

        semaforoEntradaLibre();

        cambiarEstado(VERDE_ENTRADA);

        Serial.println("Vehiculo termino de bajar");
    }

break;


        //----------------------------------------------------
case VERDE_ENTRADA:

    // Mantener el verde durante 3 segundos
    if (millis() - tiempoEstado >= TIEMPO_VERDE)
    {
        apagarTodo();
ultimoMovimiento = millis();
        cambiarEstado(REPOSO);

        Serial.println("Sistema listo");
    }

break;


//----------------------------------------------------
case VERDE_SALIDA:

    // Mantener el verde durante 3 segundos
    if (millis() - tiempoEstado >= TIEMPO_VERDE)
    {
        apagarTodo();
ultimoMovimiento = millis();
        cambiarEstado(REPOSO);

        Serial.println("Sistema listo");
    }

break;


//----------------------------------------------------
case ALARMA:

    // Parpadeo de ambos rojos
    if (millis() - tiempoParpadeo >= TIEMPO_PARPADEO)
    {
        tiempoParpadeo = millis();

        parpadeo = !parpadeo;

        digitalWrite(ROJO_ENTRADA, parpadeo);
        digitalWrite(ROJO_SALIDA, parpadeo);
    }

    // Después de 10 segundos vuelve automáticamente a REPOSO
    if (millis() - tiempoEstado >= TIEMPO_ALARMA)
    {
        apagarTodo();
ultimoMovimiento = millis();
        cambiarEstado(REPOSO);

        Serial.println("Fin de alarma");
    }

break;

    }
verificarInactividad();
}

