/***********************************************************************
 *  RampControl V1.1
 *----------------------------------------------------------------------
 *  Autor: Rodrigo Vicente + ChatGPT
 *  Plataforma: Arduino UNO R3
 *
 *  Control de una rampa de estacionamiento de un solo carril.
 *
 *  Secuencia de entrada:
 *      E1 -> E2 -> E3
 *
 *  Secuencia de salida:
 *      E3 -> E2 -> E1
 *
 *  Programación:
 *      ✔ Máquina de estados
 *      ✔ Sin delay()
 *      ✔ Prioridad entre vehículos
 *      ✔ Detección por flanco
 ***********************************************************************/

//====================== PINES ======================

// Sensores
const byte SENSOR_ENTRADA = 2;
const byte SENSOR_CENTRO  = 3;
const byte SENSOR_SALIDA  = 4;

// Semáforos
const byte ROJO_ENTRADA  = 8;
const byte ROJO_SALIDA   = 9;
const byte VERDE_ENTRADA = 10;
const byte VERDE_SALIDA  = 11;


//====================== TIEMPOS ======================

const unsigned long TIEMPO_LLEGAR_CENTRO = 15000UL;
const unsigned long TIEMPO_VERDE         = 3000UL;
const unsigned long TIEMPO_INACTIVIDAD   = 300000UL;
const unsigned long TIEMPO_PARPADEO      = 500UL;


//====================== ESTADOS ======================

enum EstadoSistema
{
    REPOSO,

    ENTRADA_ESPERA_CENTRO,
    ENTRADA_ESPERA_SALIDA,

    SALIDA_ESPERA_CENTRO,
    SALIDA_ESPERA_ENTRADA,

    VERDE_ENTRADA,
    VERDE_SALIDA,

    ALARMA
};

EstadoSistema estadoActual = REPOSO;


//====================== TEMPORIZADORES ======================

unsigned long tiempoEstado = 0;
unsigned long ultimoMovimiento = 0;
unsigned long tiempoParpadeo = 0;


//====================== VARIABLES ======================

bool parpadeo = false;


//====================== DETECCIÓN POR FLANCO ======================

bool anteriorE1 = HIGH;
bool anteriorE2 = HIGH;
bool anteriorE3 = HIGH;


//====================== FUNCIONES ======================

bool flancoEntrada()
{
    bool actual = digitalRead(SENSOR_ENTRADA);

    bool pulso = (anteriorE1 == HIGH && actual == LOW);

    anteriorE1 = actual;

    return pulso;
}

bool flancoCentro()
{
    bool actual = digitalRead(SENSOR_CENTRO);

    bool pulso = (anteriorE2 == HIGH && actual == LOW);

    anteriorE2 = actual;

    return pulso;
}

bool flancoSalida()
{
    bool actual = digitalRead(SENSOR_SALIDA);

    bool pulso = (anteriorE3 == HIGH && actual == LOW);

    anteriorE3 = actual;

    return pulso;
}


//====================== CAMBIO DE ESTADO ======================

void cambiarEstado(EstadoSistema nuevoEstado)
{
    estadoActual = nuevoEstado;
    tiempoEstado = millis();

    Serial.print("Estado -> ");
    Serial.println((int)estadoActual);
}


//====================== SEMÁFOROS ======================

void apagarTodo()
{
    digitalWrite(ROJO_ENTRADA, LOW);
    digitalWrite(ROJO_SALIDA, LOW);

    digitalWrite(VERDE_ENTRADA, LOW);
    digitalWrite(VERDE_SALIDA, LOW);
}


void semaforoEntradaBloqueada()
{
    apagarTodo();

    digitalWrite(ROJO_ENTRADA, HIGH);
}


void semaforoSalidaBloqueada()
{
    apagarTodo();

    digitalWrite(ROJO_SALIDA, HIGH);
}


void semaforoEntradaLibre()
{
    apagarTodo();

    digitalWrite(VERDE_ENTRADA, HIGH);
}


void semaforoSalidaLibre()
{
    apagarTodo();

    digitalWrite(VERDE_SALIDA, HIGH);
}


//====================== ALARMA ======================

void entrarAlarma()
{
    cambiarEstado(ALARMA);

    tiempoParpadeo = millis();

    Serial.println("***** ALARMA *****");
}
